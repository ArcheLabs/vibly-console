NEXT_PUBLIC_APP_NAME=Vibly Console
NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8787
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
NEXT_PUBLIC_VIBLY_NETWORK_ID=substrate:vibly-solo
NEXT_PUBLIC_VIBLY_NETWORK_NAME=Local

# Vibly chain RPC: used for VIB claim extrinsics.
NEXT_PUBLIC_VIBLY_RPC_URL=ws://127.0.0.1:9944

# Payment chain RPC: used by Get VIB to read DOT/PAS balance and submit transfers.
# Keep this separate from NEXT_PUBLIC_VIBLY_RPC_URL; local relay/payment node usually runs on 9945.
NEXT_PUBLIC_PAYMENT_RPC_URL=ws://127.0.0.1:9945
NEXT_PUBLIC_POLKADOT_RPC_URL=ws://127.0.0.1:9945

# Optional JSON array. Use URL arrays for fallback; Console tries the next RPC
# endpoint when the previous one is unavailable.
# NEXT_PUBLIC_VIBLY_NETWORK_PROFILES=[{"id":"substrate:vibly-solo","label":"Local","stage":"local","coordinatorUrls":["http://localhost:8787"],"paymentRpcUrls":["ws://127.0.0.1:9945"],"paymentTokenSymbol":"DOT","paymentTokenDecimals":10,"viblyRpcUrls":["ws://127.0.0.1:9944"],"relayTokenSymbol":"DOT"},{"id":"substrate:vibly-testnet","label":"Testnet","stage":"testnet","paymentRpcUrls":["wss://rpc.ibp.network/paseo","wss://paseo.dotters.network","wss://paseo-rpc.dwellir.com"],"paymentTokenSymbol":"PAS","paymentTokenDecimals":10,"viblyRpcUrls":["wss://..."],"relayTokenSymbol":"PAS"},{"id":"substrate:vibly-incentivized-testnet","label":"Incentivized Testnet","stage":"testnet","status":"prelaunch","paymentRpcUrls":["wss://rpc.polkadot.io","wss://polkadot.api.onfinality.io/public-ws","wss://polkadot-rpc.dwellir.com"],"paymentTokenSymbol":"DOT","paymentTokenDecimals":10,"viblyRpcUrls":["wss://..."],"relayTokenSymbol":"DOT"}]
NEXT_PUBLIC_VIBLY_NETWORK_MANIFEST_URL=https://vibly.network/networks.json

# Used by the Next.js proxy route when Console mode is "proxy".
COORDINATOR_URL=http://localhost:8787

# Auth.js local development config. Required because SessionProvider calls /api/auth/session.
AUTH_SECRET=dev-vibly-console-auth-secret-change-me
AUTH_TRUST_HOST=true
AUTH_DEV_CREDENTIALS=true

# Optional server-side coordinator routing by selected network id.
# If set, only the listed network ids will be routed to their own coordinator URL.
# Network ids NOT listed here will fall back to COORDINATOR_URL above.
# VIBLY_COORDINATOR_NETWORK_PROFILES=[{"id":"substrate:vibly-solo","coordinatorUrl":"http://localhost:8787"},{"id":"substrate:vibly-testnet","coordinatorUrl":"https://testnet.example:8788"},{"id":"substrate:vibly-incentivized-testnet","coordinatorUrl":"https://incentivized.example:8790"}]

# Browser transport for Coordinator calls.
# proxy: use Next.js /api/coordinator with server-side COORDINATOR_API_TOKEN.
# direct: browser calls NEXT_PUBLIC_COORDINATOR_URL directly; suitable for static hosting.
NEXT_PUBLIC_COORDINATOR_TRANSPORT=proxy
