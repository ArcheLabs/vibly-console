NEXT_PUBLIC_APP_NAME=Vibly Console
NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8787
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
NEXT_PUBLIC_VIBLY_NETWORK_ID=substrate:vibly-solo
NEXT_PUBLIC_VIBLY_NETWORK_NAME=Local
NEXT_PUBLIC_VIBLY_RPC_URL=ws://127.0.0.1:9944
# Optional JSON array:
# NEXT_PUBLIC_VIBLY_NETWORK_PROFILES=[{"id":"substrate:vibly-solo","label":"Local","stage":"local","viblyRpcUrl":"ws://127.0.0.1:9944"},{"id":"substrate:vibly-incentivized-testnet","label":"Incentivized Testnet","stage":"testnet","viblyRpcUrl":"wss://..."}]

# Used by the Next.js proxy route when Console mode is "proxy".
COORDINATOR_URL=http://localhost:8787

# Development only. The P1 coordinator default token is dev-token.
NEXT_PUBLIC_DEMO_API_TOKEN=dev-token
